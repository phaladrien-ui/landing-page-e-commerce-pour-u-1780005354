```python
import os
from PIL import Image, ImageDraw, ImageFont

# Ensure directory exists
os.makedirs('static/images', exist_ok=True)

# Create a 1200x800 image with gradient background
width, height = 1200, 800
image = Image.new('RGB', (width, height), color='black')
draw = ImageDraw.Draw(image)

# Create gradient from dark blue to black
for y in range(height):
    r = int(10 + (y / height) * 20)
    g = int(20 + (y / height) * 30)
    b = int(80 + (y / height) * 40)
    for x in range(width):
        draw.point((x, y), fill=(r, g, b))

# Draw a stylized smartwatch shape
watch_center_x, watch_center_y = width // 2, height // 2 - 50
watch_radius = 150

# Watch body (circle)
draw.ellipse(
    [watch_center_x - watch_radius, watch_center_y - watch_radius,
     watch_center_x + watch_radius, watch_center_y + watch_radius],
    fill=(30, 40, 60),
    outline=(100, 150, 200),
    width=8
)

# Watch face (inner circle)
inner_radius = 130
draw.ellipse(
    [watch_center_x - inner_radius, watch_center_y - inner_radius,
     watch_center_x + inner_radius, watch_center_y + inner_radius],
    fill=(15, 20, 35),
    outline=(60, 100, 160),
    width=3
)

# Watch strap (top)
strap_width = 60
strap_height = 100
draw.rectangle(
    [watch_center_x - strap_width // 2, watch_center_y - watch_radius - strap_height,
     watch_center_x + strap_width // 2, watch_center_y - watch_radius],
    fill=(40, 50, 70),
    outline=(80, 120, 180),
    width=3
)

# Watch strap (bottom)
draw.rectangle(
    [watch_center_x - strap_width // 2, watch_center_y + watch_radius,
     watch_center_x + strap_width // 2, watch_center_y + watch_radius + strap_height],
    fill=(40, 50, 70),
    outline=(80, 120, 180),
    width=3
)

# Add some watch face details (time display)
hour_hand_length = 60
minute_hand_length = 90
center_x, center_y = watch_center_x, watch_center_y

# Hour hand
draw.line(
    [center_x, center_y, center_x - 30, center_y - 50],
    fill=(200, 220, 255),
    width=6
)

# Minute hand
draw.line(
    [center_x, center_y, center_x + 70, center_y - 20],
    fill=(180, 200, 240),
    width=4
)

# Center dot
draw.ellipse(
    [center_x - 8, center_y - 8, center_x + 8, center_y + 8],
    fill=(100, 150, 220)
)

# Add some glowing dots around the watch face
for i in range(12):
    angle = i * 30 * 3.14159 / 180
    dot_x = center_x + int(110 * 0.8 * (angle if i < 6 else -angle))
    dot_y = center_y + int(110 * 0.8 * (angle if i < 6 else -angle))
    # Simplified dot placement
    dot_x = center_x + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    dot_y = center_y + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    # Better dot placement using sin/cos
    dot_x = center_x + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    dot_y = center_y + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))

# Proper dot placement
for i in range(12):
    angle = i * 30 * 3.14159 / 180
    dot_x = center_x + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    dot_y = center_y + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    # Use proper trigonometric placement
    dot_x = center_x + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))
    dot_y = center_y + int(110 * (0.8 if i % 3 == 0 else 0.5) * (1 if i < 6 else -1))

# Correct dot placement with trigonometry
import math
for i in range(12):
    angle = i * 30 * math.pi / 180
    radius = 110 * (0.8 if i % 3 == 0 else 0.5)
    dot_x = center_x + int(radius * math.cos(angle))
    dot_y = center_y + int(radius * math.sin(angle))
    dot_size = 6 if i % 3 == 0 else 3
    draw.ellipse(
        [dot_x - dot_size, dot_y - dot_size, dot_x + dot_size, dot_y + dot_size],
        fill=(100, 150, 220) if i % 3 == 0 else (60, 100, 160)
    )

# Add text "LUXE" below the watch
try:
    font = ImageFont.truetype("arial.ttf", 60)
except:
    font = ImageFont.load_default()

text = "LUXE"
text_bbox = draw.textbbox((0, 0), text, font=font)
text_width = text_bbox[2] - text_bbox[0]
text_x = (width - text_width) // 2
text_y = watch_center_y + watch_radius + strap_height + 60
draw.text((text_x, text_y), text, fill=(180, 200, 240), font=font)

# Add subtitle
try:
    font_small = ImageFont.truetype("arial.ttf", 30)
except:
    font_small = ImageFont.load_default()

subtitle = "SMART CONNECTED"
subtitle_bbox = draw.textbbox((0, 0), subtitle, font=font_small)
subtitle_width = subtitle_bbox[2] - subtitle_bbox[0]
subtitle_x = (width - subtitle_width) // 2
subtitle_y = text_y + 70
draw.text((subtitle_x, subtitle_y), subtitle, fill=(100, 150, 200), font=font_small)

# Add some decorative lines
line_y = subtitle_y + 50
draw.line([width // 2 - 100, line_y, width // 2 + 100, line_y], fill=(60, 100, 160), width=2)

# Add small stars/sparkles
for _ in range(20):
    import random
    sx = random.randint(0, width)
    sy = random.randint(0, height)
    size = random.randint(1, 3)
    brightness = random.randint(100, 200)
    draw.ellipse(
        [sx - size, sy - size, sx + size, sy + size],
        fill=(brightness, brightness, 255)
    )

# Save the image
image.save('static/images/cta.jpg', 'JPEG', quality=95)
print("Image created successfully at static/images/cta.jpg")
```