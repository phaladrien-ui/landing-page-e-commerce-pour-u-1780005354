```python
import os
from PIL import Image, ImageDraw, ImageFont

def create_features_image():
    # Create directory if it doesn't exist
    os.makedirs('static/images', exist_ok=True)
    
    # Create a new image with gradient background
    width, height = 1200, 800
    image = Image.new('RGB', (width, height), color='#1a1a2e')
    draw = ImageDraw.Draw(image)
    
    # Create gradient effect
    for i in range(height):
        color = (
            int(26 + (16 * i / height)),
            int(26 + (20 * i / height)),
            int(46 + (30 * i / height))
        )
        draw.line([(0, i), (width, i)], fill=color)
    
    # Draw watch silhouette
    watch_center_x = width // 2
    watch_center_y = height // 2
    
    # Watch body
    draw.ellipse(
        [watch_center_x - 150, watch_center_y - 150, 
         watch_center_x + 150, watch_center_y + 150],
        outline='#c9a84c',
        width=8
    )
    
    # Watch face
    draw.ellipse(
        [watch_center_x - 130, watch_center_y - 130, 
         watch_center_x + 130, watch_center_y + 130],
        fill='#0f3460'
    )
    
    # Watch dial details
    for angle in range(0, 360, 30):
        import math
        rad = math.radians(angle)
        x1 = watch_center_x + 100 * math.cos(rad)
        y1 = watch_center_y + 100 * math.sin(rad)
        x2 = watch_center_x + 120 * math.cos(rad)
        y2 = watch_center_y + 120 * math.sin(rad)
        draw.line([(x1, y1), (x2, y2)], fill='#c9a84c', width=3)
    
    # Watch hands
    draw.line([(watch_center_x, watch_center_y), 
               (watch_center_x + 60, watch_center_y - 60)], 
              fill='#c9a84c', width=4)
    draw.line([(watch_center_x, watch_center_y), 
               (watch_center_x - 40, watch_center_y + 70)], 
              fill='#c9a84c', width=3)
    
    # Center dot
    draw.ellipse(
        [watch_center_x - 8, watch_center_y - 8, 
         watch_center_x + 8, watch_center_y + 8],
        fill='#c9a84c'
    )
    
    # Strap
    draw.rectangle(
        [watch_center_x - 40, watch_center_y + 150, 
         watch_center_x + 40, watch_center_y + 250],
        fill='#2d2d44',
        outline='#c9a84c',
        width=2
    )
    
    draw.rectangle(
        [watch_center_x - 40, watch_center_y - 250, 
         watch_center_x + 40, watch_center_y - 150],
        fill='#2d2d44',
        outline='#c9a84c',
        width=2
    )
    
    # Feature icons around the watch
    features = [
        ('📡', 'GPS', 100, 100),
        ('💓', 'Heart Rate', width - 200, 100),
        ('🌊', 'Water Resistant', 100, height - 100),
        ('📱', 'Smart Notifications', width - 250, height - 100),
        ('⚡', 'Fast Charging', width // 2 - 50, 50),
        ('🎵', 'Music Control', width // 2 - 50, height - 60)
    ]
    
    try:
        font_large = ImageFont.truetype("arial.ttf", 40)
        font_small = ImageFont.truetype("arial.ttf", 20)
    except:
        font_large = ImageFont.load_default()
        font_small = ImageFont.load_default()
    
    for icon, text, x, y in features:
        draw.text((x, y), icon, fill='#c9a84c', font=font_large)
        draw.text((x + 50, y + 5), text, fill='#e0e0e0', font=font_small)
    
    # Title
    title = "LUXURY SMARTWATCH"
    subtitle = "Premium Features"
    
    # Get text size for centering
    title_bbox = draw.textbbox((0, 0), title, font=font_large)
    title_width = title_bbox[2] - title_bbox[0]
    title_x = (width - title_width) // 2
    
    draw.text((title_x, 30), title, fill='#c9a84c', font=font_large)
    
    subtitle_bbox = draw.textbbox((0, 0), subtitle, font=font_small)
    subtitle_width = subtitle_bbox[2] - subtitle_bbox[0]
    subtitle_x = (width - subtitle_width) // 2
    
    draw.text((subtitle_x, 80), subtitle, fill='#e0e0e0', font=font_small)
    
    # Decorative lines
    draw.line([(50, 25), (title_x - 20, 25)], fill='#c9a84c', width=2)
    draw.line([(title_x + title_width + 20, 25), (width - 50, 25)], fill='#c9a84c', width=2)
    
    # Save image
    image.save('static/images/features.jpg', 'JPEG', quality=95)
    print("Features image created successfully!")

if __name__ == "__main__":
    create_features_image()
```